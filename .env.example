# App
NODE_ENV=development

# Backend
PORT=3001
DATABASE_PATH=./data/diary.sqlite
UPLOAD_DIR=./uploads
SESSION_SECRET=change-me-to-a-random-string-at-least-32-chars
PIN_SALT_ROUNDS=12
SESSION_EXPIRY_HOURS=72

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
RATE_LIMIT_PIN_TTL=60
RATE_LIMIT_PIN_MAX=5

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
